# AetherOS Environment Configuration

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://aetheros:aetheros@localhost:5432/aetheros
REDIS_URL=redis://localhost:6379/0

# AI Providers (configure at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default AI routing
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
FALLBACK_LLM_PROVIDER=ollama
FALLBACK_LLM_MODEL=llama3.2

# Voice
WHISPER_MODEL=base
TTS_ENGINE=edge

# Vision
VISION_MODEL=yolov8n.pt
WEBCAM_ENABLED=true

# Memory
CHROMA_HOST=localhost
CHROMA_PORT=8001
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Agents
AGENT_MAX_ITERATIONS=10
AGENT_APPROVAL_MODE=true

# Telemetry
TELEMETRY_INTERVAL_MS=1000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
